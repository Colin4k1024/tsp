{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECC Install Modules",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "rules",
              "agents",
              "commands",
              "hooks",
              "platform",
              "orchestration",
              "skills"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "claude",
                "cursor",
                "antigravity",
                "codex",
                "gemini",
                "opencode",
                "codebuddy",
                "copilot",
                "windsurf",
                "augment"
              ]
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          },
          "defaultInstall": {
            "type": "boolean"
          },
          "cost": {
            "type": "string",
            "enum": [
              "light",
              "medium",
              "heavy"
            ]
          },
          "stability": {
            "type": "string",
            "enum": [
              "experimental",
              "beta",
              "stable"
            ]
          },
          "externalInstall": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "profiles": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "failureMode": {
                "type": "string",
                "enum": [
                  "error",
                  "warn"
                ]
              },
              "failureHint": {
                "type": "string"
              },
              "command": {
                "type": "string",
                "minLength": 1
              },
              "script": {
                "type": "string",
                "minLength": 1
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "description",
              "command",
              "script",
              "args"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "kind",
          "description",
          "paths",
          "targets",
          "dependencies",
          "defaultInstall",
          "cost",
          "stability"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "modules"
  ],
  "additionalProperties": false
}
